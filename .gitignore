# ============================
# Node.js dependencies
# ============================
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================
# Testing / coverage
# ============================
/coverage

# ============================
# Next.js
# ============================
/.next/
/out/
.next-env.d.ts

# ============================
# Production build
# ============================
/build

# ============================
# Environment files
# ============================
# Ignore all env files (secrets)
.env*
# But allow example/template file
!.env.example

# ============================
# Logs / debug
# ============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================
# OS / misc
# ============================
.DS_Store
*.pem

# ============================
# Vercel / hosting
# ============================
.vercel

# ============================
# TypeScript
# ============================
*.tsbuildinfo

# ============================
# Optional editor/IDE settings (uncomment if used)
# ============================
#.vscode/